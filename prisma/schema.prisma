generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Trainer {
  id         String   @id @default(uuid())
  authUserId String?  @unique @map("auth_user_id")
  name       String
  email      String   @unique
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("trainers")
}